# -----------------------------------------------------------------------------
# Environment variable template — Phase 2 (Development Environment & Tooling)
#
# Copy this file to `.env` (never commit `.env` itself — it is git-ignored)
# and adjust values as needed:
#
#   cp .env.example .env
#
# This file intentionally contains ONLY the variables meaningful at the
# current phase. Variables for services introduced in later phases
# (PostgreSQL, Redis, Qdrant, MinIO in Phase 3; JWT/auth secrets in Phase 6;
# SLM serving config in Phase 15; etc.) will be appended to this file in
# those phases — not added speculatively now.
# -----------------------------------------------------------------------------

# General application environment.
# One of: development | testing | production
ENVIRONMENT=development

# Logging verbosity for local tooling and (later) the backend application.
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Human-readable application name, used in logs and (later) API metadata.
APP_NAME=ai-code-review-framework
